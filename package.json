{
  "name": "mentoria-qa-desafio4-grupo22",
  "version": "1.0.0",
  "description": "API REST para cadastro de viagens dos sonhos",
  "main": "src/app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test": "jest",
    "test:json": "jest --runInBand --json --outputFile=reports/latest-run.json",
    "history:save": "node scripts/save-history.js",
    "history:dashboard": "node scripts/generate-dashboard.js",
    "test:history": "node scripts/run-history.js",
    "test:dash": "node scripts/run-history.js",
    "test:postman": "newman run viagens.postman_collection.json -r \"cli,htmlextra\" --reporter-htmlextra-export reports/newman-report.html"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "rest"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "allure-commandline": "^2.38.1",
    "jest": "^30.3.0",
    "jest-allure2-reporter": "^2.3.0",
    "jest-html-reporters": "^3.1.7",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
