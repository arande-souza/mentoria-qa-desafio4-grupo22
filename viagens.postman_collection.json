{
  "info": {
    "name": "API Viagens - Testes Automatizados",
    "_postman_id": "viagens-collection-completa",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection baseada nos testes Jest da API de Viagens."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "00 - Setup",
      "item": [
        {
          "name": "Limpar variáveis de execução",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.unset('destinoDuplicado');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Setup executado', function () {",
                  "  pm.expect(true).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Cenários principais",
      "item": [
        {
          "name": "CT17 - deve criar uma nova viagem com dados validos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"Paris, Franca\",\n  \"orcamento\": 5000,\n  \"atividades\": [\"Visitar a Torre Eiffel\", \"Passear pelo Louvre\"],\n  \"dias\": 7,\n  \"status\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response deve ter id numérico', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Campos retornados devem estar corretos', function () {",
                  "  pm.expect(json.destino).to.eql('Paris, Franca');",
                  "  pm.expect(json.orcamento).to.eql(5000);",
                  "  pm.expect(json.atividades).to.eql(['Visitar a Torre Eiffel', 'Passear pelo Louvre']);",
                  "  pm.expect(json.dias).to.eql(7);",
                  "  pm.expect(json.status).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CT11 - deve retornar sucesso para status viagem realizada = false",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"Viagem ainda nao realizada Teste\",\n  \"orcamento\": 10,\n  \"atividades\": [\"Atividade Teste\"],\n  \"dias\": 5,\n  \"status\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Status retornado deve ser false', function () {",
                  "  pm.expect(json.status).to.eql(false);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CT12 - deve retornar sucesso para status viagem realizada = true",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"Viagem realizada Teste\",\n  \"orcamento\": 10,\n  \"atividades\": [\"Atividade Teste\"],\n  \"dias\": 5,\n  \"status\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Status retornado deve ser true', function () {",
                  "  pm.expect(json.status).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "CT16 - deve retornar erros ao enviar campos vazios",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"\",\n  \"orcamento\": null,\n  \"atividades\": [],\n  \"dias\": null,\n  \"status\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response deve conter errors como array', function () {",
                  "  pm.expect(json).to.have.property('errors');",
                  "  pm.expect(json.errors).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Deve conter os erros esperados', function () {",
                  "  pm.expect(json.errors).to.include(\"O campo 'destino' nao pode ser vazio.\");",
                  "  pm.expect(json.errors).to.include(\"O campo 'orcamento' deve ser um numero valido.\");",
                  "  pm.expect(json.errors).to.include(\"O campo 'atividades' deve conter entre 1 e 10 itens.\");",
                  "  pm.expect(json.errors).to.include(\"O campo 'dias' deve ser um numero inteiro.\");",
                  "  pm.expect(json.errors).to.include(\"O campo 'status' deve ser um boolean.\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Duplicidade",
      "item": [
        {
          "name": "CT04 - passo 1 - criar destino base",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"Destino Duplicado Teste\",\n  \"orcamento\": 1000,\n  \"atividades\": [\"Visitar a Torre Eiffel\"],\n  \"dias\": 5,\n  \"status\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Primeira criação deve retornar 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.collectionVariables.set('destinoDuplicado', 'Destino Duplicado Teste');"
                ]
              }
            }
          ]
        },
        {
          "name": "CT04 - passo 2 - deve retornar erro 409 para destino duplicado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/viagens",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destino\": \"{{destinoDuplicado}}\",\n  \"orcamento\": 1000,\n  \"atividades\": [\"Visitar a Torre Eiffel\"],\n  \"dias\": 5,\n  \"status\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Mensagem de erro deve estar correta', function () {",
                  "  pm.expect(json.error).to.eql('Ja existe uma viagem cadastrada para esse destino.');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
